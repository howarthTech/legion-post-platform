{{- with .Spec -}}
# CRM container for {{ .PostName }} — generated by legion-post-platform.
# Add this service to the platform's docker-compose on the VPS, or run it as
# its own compose project under /srv/apps/crm-{{ .Client }}/.
#
# Uses the SHARED CRM image. The image always listens on 0.0.0.0:8081 INSIDE
# the container; only the published host port ({{ .CRMPort }}) and the env +
# volume differ per client. Caddy reverse-proxies admin.{{ .Domain }} to the
# host port. Do NOT set LISTEN_ADDR in the env file — the image default is
# correct for the container.

services:
  crm-{{ .Client }}:
    image: ghcr.io/howarthtech/legion-rome-crm:latest
    container_name: crm-{{ .Client }}
    restart: unless-stopped
    env_file: /srv/secrets/crm-{{ .Client }}.env
    ports:
      - "127.0.0.1:{{ .CRMPort }}:8081"
    volumes:
      - crm-{{ .Client }}-data:/data
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://127.0.0.1:8081/healthz"]
      interval: 30s
      timeout: 5s
      retries: 3
    deploy:
      resources:
        limits:
          cpus: "0.25"
          memory: 128m
          pids: 200

volumes:
  crm-{{ .Client }}-data:
{{- end }}
