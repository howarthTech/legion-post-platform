{{- with .Spec -}}
# CRM container for {{ .PostName }} — generated by legion-post-platform.
# Add this service to the platform's docker-compose on the VPS, or run it as
# its own compose project under /srv/apps/crm-{{ .Client }}/.
#
# Uses the SHARED CRM image; only env + volume + port differ per client.

services:
  crm-{{ .Client }}:
    image: ghcr.io/howarthtech/legion-rome-crm:latest
    container_name: crm-{{ .Client }}
    restart: unless-stopped
    env_file: /srv/secrets/crm-{{ .Client }}.env
    ports:
      - "127.0.0.1:{{ .CRMPort }}:{{ .CRMPort }}"
    volumes:
      - crm-{{ .Client }}-data:/data
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://127.0.0.1:{{ .CRMPort }}/healthz"]
      interval: 30s
      timeout: 5s
      retries: 3
    deploy:
      resources:
        limits:
          cpus: "0.25"
          memory: 128m
          pids: 200

volumes:
  crm-{{ .Client }}-data:
{{- end }}
