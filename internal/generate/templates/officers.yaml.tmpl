{{- with .Spec -}}
# Officer roster for {{ .PostName }} — generated by legion-post-platform.
officers:
{{- range .Officers }}
  - role: "{{ .Role }}"
    name: "{{ .Name }}"
    phone: "{{ .Phone }}"
    email: "{{ .Email }}"
    weight: {{ .Weight }}
{{- end }}

family_contacts:
{{- range .FamilyContacts }}
  - role: "{{ .Role }}"
    name: "{{ .Name }}"
    phone: "{{ .Phone }}"
    weight: {{ .Weight }}
{{- end }}
{{- end }}
