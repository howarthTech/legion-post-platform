{{- with .Spec -}}
# Caddy site block for {{ .Domain }} — generated by legion-post-platform.
# Deploy to /etc/caddy/sites/{{ .Domain }}.caddy on the VPS.
# Mirrors the reference instance (romelegion.org). Add 301 redirects from the
# post's old URLs here at cutover.

{{ .Domain }} {
    root * /srv/www/{{ .Domain }}

    encode zstd gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Permissions-Policy "interest-cohort=()"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    @assets {
        path *.css *.js *.woff *.woff2 *.jpg *.jpeg *.png *.webp *.avif *.svg *.ico *.ics
    }
    header @assets Cache-Control "public, max-age=31536000, immutable"

    @html path *.html /
    header @html Cache-Control "public, max-age=300, must-revalidate"

    # Form endpoints (only if this post has Resend-backed forms wired up)
    @formContact path /_form/contact.php
    @formApplication path /_form/application.php
    handle @formContact {
        php_fastcgi 127.0.0.1:9000
    }
    handle @formApplication {
        php_fastcgi 127.0.0.1:9000
    }
    @otherPhp path *.php
    respond @otherPhp 404

    try_files {path} {path}/ {path}.html
    file_server

    handle_errors {
        @404 expression {http.error.status_code} == 404
        rewrite @404 /404.html
        file_server
    }

    log {
        output file /var/log/caddy/{{ .Domain }}.access.log {
            roll_size 50mb
            roll_keep 5
        }
        format console
    }
}

www.{{ .Domain }} {
    redir https://{{ .Domain }}{uri} 308
}
{{- end }}
