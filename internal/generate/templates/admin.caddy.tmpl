{{- with .Spec -}}
# Caddy block for the CRM admin at admin.{{ .Domain }} — generated by
# legion-post-platform. Deploy to /etc/caddy/sites/admin.{{ .Domain }}.caddy.
# Reverse-proxies to this client's CRM container on its loopback port.

admin.{{ .Domain }} {
    encode zstd gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "same-origin"
        X-Robots-Tag "noindex, nofollow"
        -Server
    }

    reverse_proxy 127.0.0.1:{{ .CRMPort }}

    log {
        output file /var/log/caddy/admin.{{ .Domain }}.access.log {
            roll_size 50mb
            roll_keep 5
        }
        format console
    }
}
{{- end }}
