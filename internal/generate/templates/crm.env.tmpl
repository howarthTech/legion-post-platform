{{- with .Spec -}}
# CRM secrets for {{ .PostName }} — generated by legion-post-platform.
# Deploy to /srv/secrets/crm-{{ .Client }}.env on the VPS (mode 600, root-owned).
# Generated secrets below are one-time; the admin password is shown in
# CHECKLIST.md and is NOT recoverable from this file (only its bcrypt hash).

# NOTE: do not set LISTEN_ADDR or DB_PATH here — the container image already
# defaults them correctly (0.0.0.0:8081 inside the container, /data/crm.db on
# the mounted volume). The published host port is set in the compose file.
PUBLIC_URL=https://admin.{{ .Domain }}
ORG_NAME={{ .PostName }}
ORG_TIMEZONE={{ .Timezone }}
EVENTS_FEED_URL={{ .EventsFeedURL }}

ADMIN_USERNAME={{ .AdminUsername }}
ADMIN_PASSWORD_HASH={{ $.AdminHash }}
SESSION_SECRET={{ $.SessionSecret }}

# Fill these in once the post's Twilio subaccount + number are provisioned.
# Leave empty for dry-run mode (sends log to stdout, nothing transmitted).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
{{- end }}
