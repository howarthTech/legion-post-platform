{{- with .Spec -}}
# Hugo configuration for {{ .Domain }}
# {{ .PostName }} — generated by legion-post-platform.
# Edit freely; this is the instance's own config from here on.

baseURL = "https://{{ .Domain }}/"
languageCode = "en-us"
title = "American Legion {{ .PostShortName }} — {{ .Locality }}, {{ .Region }}"
theme = "legion-post-theme"
enableRobotsTXT = true
enableGitInfo = false
buildFuture = true
disableKinds = ["taxonomy", "term"]

# (events intentionally has NO permalink pattern: event pages come from the
# client's CRM via the events content adapter; the adapter path is the slug.)
[permalinks]
  news = "/news/:slug/"

[markup]
  [markup.goldmark.renderer]
    unsafe = true
  [markup.tableOfContents]
    startLevel = 2
    endLevel = 3

[imaging]
  resampleFilter = "Lanczos"
  quality = 82
  anchor = "Smart"

[params]
  description = "{{ .Description }}"
  ogImage = "images/hero.jpg"
  postName = "{{ .PostName }}"
  postShortName = "{{ .PostShortName }}"
  charterYear = {{ .CharterYear }}
  mailingAddress = "{{ .MailingAddress }}"
  meetingLocation = "{{ .MeetingLocation }}"
  meetingSchedule = "{{ .MeetingSchedule }}"
  postEmail = "{{ .Email }}"
  postPhone = "{{ .Phone }}"
  facebookURL = "{{ .FacebookURL }}"
  heroTitle = "{{ .HeroTitle }}"
  heroImageAlt = "{{ .HeroImageAlt }}"
  heroBgImage = "images/hero-bg.jpg"
  heroImage = "images/hero.jpg"
  locality = "{{ .Locality }}"
  region = "{{ .Region }}"
  regionLong = "{{ .RegionLong }}"
  serviceArea = "{{ .ServiceArea }}"
  facebookSearch = "{{ .FacebookSearch }}"
  schemaAltName = "{{ .FacebookSearch }}"
  timezone = "{{ .Timezone }}"

  # The client CRM's public feeds — the site builds its events, its
  # officer/family roster, and its photo gallery from these at build time. The
  # CRM is the source of truth; content is authored there, not in this repo.
  eventsAPI = "https://admin.{{ .Domain }}/api/events.json"
  contentAPI = "https://admin.{{ .Domain }}/api/site.json"
  galleryAPI = "https://admin.{{ .Domain }}/api/gallery.json"

# [params.*] sub-tables must come after all direct keys above.
[params.postal]
  street = "{{ .Postal.Street }}"
  locality = "{{ .Postal.Locality }}"
  region = "{{ .Postal.Region }}"
  postalCode = "{{ .Postal.PostalCode }}"

[params.venue]
  name = "{{ .Venue.Name }}"
  street = "{{ .Venue.Street }}"
  locality = "{{ .Venue.Locality }}"
  region = "{{ .Venue.Region }}"
  postalCode = "{{ .Venue.PostalCode }}"
{{ if .MapShortlinks }}
[params.mapShortlinks]
{{- range $needle, $url := .MapShortlinks }}
  "{{ $needle }}" = "{{ $url }}"
{{- end }}
{{ end -}}
{{ if .Brand }}
[params.brand]
{{- range $k, $v := .Brand }}
  {{ $k }} = "{{ $v }}"
{{- end }}
{{ end }}
[outputFormats]
  [outputFormats.EventCal]
    mediaType = "text/calendar"
    baseName = "event"
    isPlainText = true
  [outputFormats.EventsJSON]
    mediaType = "application/json"
    baseName = "events"
    isPlainText = true
  [outputFormats.EventsICS]
    mediaType = "text/calendar"
    baseName = "calendar"
    isPlainText = true

[outputs]
  home = ["HTML", "RSS"]
  section = ["HTML", "RSS"]

[menu]
  [[menu.main]]
    name = "Home"
    url = "/"
    weight = 10
  [[menu.main]]
    name = "About"
    url = "/about/"
    weight = 20
  [[menu.main]]
    name = "Membership"
    url = "/membership/"
    weight = 30
  [[menu.main]]
    name = "Events"
    url = "/events/"
    weight = 40
  [[menu.main]]
    name = "Auxiliary & SAL"
    url = "/family/"
    weight = 50
  [[menu.main]]
    name = "Hall Rental"
    url = "/rental/"
    weight = 60
  [[menu.main]]
    name = "Gallery"
    url = "/gallery/"
    weight = 65
  [[menu.main]]
    name = "Contact"
    url = "/contact/"
    weight = 70

[[menu.footer]]
  name = "Flag Etiquette"
  url = "/flag-etiquette/"
  weight = 10
[[menu.footer]]
  name = "Accessibility"
  url = "/accessibility/"
  weight = 15
[[menu.footer]]
  name = "The American Legion (National)"
  url = "https://www.legion.org/"
  weight = 20
[[menu.footer]]
  name = "myLegion Portal"
  url = "https://mylegion.org/PersonifyEbusiness/Home"
  weight = 40
{{- end }}
